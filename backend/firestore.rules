rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isResourceOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isNewResourceOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }

    // User Profiles
    match /user_profiles/{profileId} {
      allow read: if isAuthenticated() && isResourceOwner();
      allow create: if isAuthenticated() && isNewResourceOwner();
      allow update, delete: if isAuthenticated() && isResourceOwner();
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && isResourceOwner();
      allow create: if isAuthenticated() && isNewResourceOwner();
      allow update, delete: if isAuthenticated() && isResourceOwner();
    }

    // Events
    match /events/{eventId} {
      allow read: if isAuthenticated() && isResourceOwner();
      allow create: if isAuthenticated() && isNewResourceOwner();
      allow update, delete: if isAuthenticated() && isResourceOwner();
    }

    // Event Task Links
    match /event_task_links/{linkId} {
      allow read: if isAuthenticated() && isOwnerOfExistingLink();
      allow write: if isAuthenticated() && isOwnerOfNewLink();

      function isOwnerOfExistingLink() {
        let eventDoc = get(/databases/$(database)/documents/events/$(resource.data.eventId));
        let taskDoc = get(/databases/$(database)/documents/tasks/$(resource.data.taskId));
        return request.auth.uid == eventDoc.data.userId && request.auth.uid == taskDoc.data.userId;
      }

      function isOwnerOfNewLink() {
        let eventDoc = get(/databases/$(database)/documents/events/$(request.resource.data.eventId));
        let taskDoc = get(/databases/$(database)/documents/tasks/$(request.resource.data.taskId));
        return request.auth.uid == eventDoc.data.userId && request.auth.uid == taskDoc.data.userId;
      }
    }

    // Courses
    match /courses/{courseId} {
      allow read: if isAuthenticated() && isResourceOwner();
      allow create: if isAuthenticated() && isNewResourceOwner();
      allow update, delete: if isAuthenticated() && isResourceOwner();
    }

    // Term Configs
    match /term_configs/{termId} {
      allow read: if isAuthenticated() && isResourceOwner();
      allow create: if isAuthenticated() && isNewResourceOwner();
      allow update, delete: if isAuthenticated() && isResourceOwner();
    }

    // User Daily Logs
    match /user_daily_logs/{logId} {
      allow read: if isAuthenticated() && isResourceOwner();
      allow create: if isAuthenticated() && isNewResourceOwner();
      allow update, delete: if isAuthenticated() && isResourceOwner();
    }
  }
}
