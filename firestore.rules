rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // User Profiles
    match /user_profiles/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Term Configs
    match /term_configs/{termId} {
      allow read, write: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
    }

    // Tasks
    match /tasks/{taskId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // Events
    match /events/{eventId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // Courses
    match /courses/{courseId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // User Daily Logs
    match /user_daily_logs/{logId} {
      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // Event Task Links
    match /event_task_links/{linkId} {
      allow read: if isSignedIn() && isOwnerOfExistingLink();
      allow write: if isSignedIn() && isOwnerOfNewLink();

      function isOwnerOfExistingLink() {
        let eventDoc = get(/databases/$(database)/documents/events/$(resource.data.event_id));
        let taskDoc = get(/databases/$(database)/documents/tasks/$(resource.data.task_id));
        return request.auth.uid == eventDoc.data.user_id
            && request.auth.uid == taskDoc.data.user_id;
      }

      function isOwnerOfNewLink() {
        let eventDoc = get(/databases/$(database)/documents/events/$(request.resource.data.event_id));
        let taskDoc = get(/databases/$(database)/documents/tasks/$(request.resource.data.task_id));
        return request.auth.uid == eventDoc.data.user_id
            && request.auth.uid == taskDoc.data.user_id;
      }
    }
  }
}
